{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(jq -r '.tool_input.file_path'); if echo \"$file_path\" | grep -q '\\.rs$'; then cargo fmt -- \"$file_path\"; fi"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/boykush/github/boykush/repositories/scraps/.codex/hooks/setup-remote.sh'",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
